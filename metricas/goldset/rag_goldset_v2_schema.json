{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RAG Juridico Gold Set v2",
  "type": "object",
  "required": ["version", "cases"],
  "properties": {
    "version": {"type": "string"},
    "description": {"type": "string"},
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "scenario", "query", "expected"],
        "properties": {
          "id": {"type": "string"},
          "scenario": {
            "type": "string",
            "enum": ["revogacao", "veto", "conflito_temporal", "citacao_obrigatoria"]
          },
          "query": {"type": "string"},
          "expected": {
            "type": "object",
            "required": ["must_signal", "must_cite", "forbidden"],
            "properties": {
              "must_signal": {"type": "array", "items": {"type": "string"}},
              "must_cite": {"type": "array", "items": {"type": "string"}},
              "forbidden": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    }
  }
}
