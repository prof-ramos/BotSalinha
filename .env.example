# ================================================
# BotSalinha — Configuração de Ambiente
# ================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env em controle de versão.
#
# Formato suportado:
#   Simples (sem prefixo):   DISCORD_BOT_TOKEN=...
#   Prefixado (canônico):    BOTSALINHA_DISCORD__TOKEN=...
# Ambos funcionam. O formato prefixado tem precedência.
# ================================================

# --------------------------------
# Discord
# --------------------------------
# Obtenha em: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Prefixo dos comandos do bot (padrão: !)
COMMAND_PREFIX=!

# --------------------------------
# OpenAI (provedor padrão de IA)
# --------------------------------
# Obtenha em: https://platform.openai.com/
# Obs: modelo e provedor são configurados em config.yaml, não aqui.
#
# Formato canônico (com prefixo BOTSALINHA_): RECOMENDADO
BOTSALINHA_OPENAI__API_KEY=your_openai_api_key_here
#
# Formato legado (sem prefixo): funciona para compatibilidade
# OPENAI_API_KEY=your_openai_api_key_here

# --------------------------------
# Google AI / Gemini (provedor alternativo)
# --------------------------------
# Obtenha em: https://ai.google.dev/
# Para usar o Google, defina model.provider como "google" no config.yaml.
GOOGLE_API_KEY=your_google_api_key_here

# --------------------------------
# OpenRouter (opcional — acesso a múltiplos modelos via API OpenAI-compatível)
# --------------------------------
# Obtenha em: https://openrouter.ai/
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# --------------------------------
# Banco de Dados
# --------------------------------
# Caminho do SQLite (relativo à raiz do projeto)
DATABASE_URL=sqlite:///data/botsalinha.db

# Tempo máximo de retenção de conversas (dias)
MAX_CONVERSATION_AGE_DAYS=30

# --------------------------------
# Configuração do Bot
# --------------------------------
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Número de rodadas de conversa mantidas no contexto
HISTORY_RUNS=3

# Ambiente: development ou production
APP_ENV=development

# --------------------------------
# Rate Limiting
# --------------------------------
# Máximo de requisições por usuário na janela de tempo
RATE_LIMIT_REQUESTS=10

# Tamanho da janela de tempo em segundos
RATE_LIMIT_WINDOW_SECONDS=60

# --------------------------------
# Retry (resiliência de chamadas à API de IA)
# --------------------------------
# Número máximo de tentativas
MAX_RETRIES=3

# Delay inicial entre tentativas (segundos)
RETRY_DELAY_SECONDS=1

# Delay máximo entre tentativas (segundos)
RETRY_MAX_DELAY_SECONDS=60
